{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Usage Monitor",
  "mainBinaryName": "claude-usage-monitor",
  "version": "0.1.0",
  "identifier": "com.rafael.claude-usage-monitor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Claude Usage Monitor",
        "width": 190,
        "height": 56,
        "minWidth": 150,
        "minHeight": 44,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "shadow": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "category": "Utility",
    "shortDescription": "Claude usage & quota monitor",
    "longDescription": "Pinnable desktop widget that monitors Claude plan quota (5h / weekly with reset countdowns) and today's token usage & equivalent cost.",
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1"
        ]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
